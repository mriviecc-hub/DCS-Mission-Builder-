-- Generated dynamic CAP logic (MOOSE SPAWN)
-- Keeps a defending red flight regenerating near the objective instead of
-- a one-shot static patrol, and lets the player know when bandits are up.

local capTemplateName = "$cap_template_name"
local capSpawn = SPAWN:New(capTemplateName)
capSpawn:InitLimit($max_alive_units, $max_groups)
capSpawn:InitRandomizeRoute(1, 3, 2000)
capSpawn:Spawn()
capSpawn:SpawnScheduled($respawn_interval_seconds, 0.3)

MESSAGE:New("Bandits airborne near $target_area_name. Weapons free.", 15):ToBlue()
